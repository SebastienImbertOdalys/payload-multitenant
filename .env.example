# ─────────────────────────────────────────────────────────────────
# ENVIRONMENT CONFIGURATION
# Copy to .env.local and fill with your values
# ─────────────────────────────────────────────────────────────────

# Node Environment
NODE_ENV=production

# ─────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────────

# Choose adapter: 'postgres' or 'mongodb'
# For Vercel: postgres is recommended (more stable on serverless)
DATABASE_ADAPTER=postgres

# PostgreSQL (Recommended for Vercel)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/payload

# MongoDB (Alternative)
# Uncomment to use MongoDB instead of Postgres
# DATABASE_URL=mongodb://localhost:27017/payload
# For MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/dbname

# ─────────────────────────────────────────────────────────────────
# PAYLOAD CMS CONFIGURATION
# ─────────────────────────────────────────────────────────────────

# Secret key for signing JWTs and cookies
# Generate: openssl rand -base64 32
# MUST be at least 32 characters
PAYLOAD_SECRET=change_me_in_production_min_32_chars

# Public server URL (used in emails, previews, etc.)
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# FILE STORAGE (Vercel Blob)
# ─────────────────────────────────────────────────────────────────

# Optional: Enable Vercel Blob for file uploads
# Get token from: https://vercel.com/docs/storage/vercel-blob
# Leave empty to use local filesystem (default)
BLOB_READ_WRITE_TOKEN=

# ─────────────────────────────────────────────────────────────────
# DATABASE SEEDING
# ─────────────────────────────────────────────────────────────────

# Only set to 'true' on first deployment to seed initial data
SEED_DB=false

# ─────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT ONLY (Docker Compose)
# ─────────────────────────────────────────────────────────────────

# Mongo Express web UI credentials (if using docker-compose --profile dev)
ME_BASICAUTH_USERNAME=admin
ME_BASICAUTH_PASSWORD=admin
