# ── Local dev (without Docker) ────────────────────────────────────
# DATABASE_URL=mongodb://127.0.0.1/payload-example-multi-tenant
# POSTGRES_URL=postgres://127.0.0.1:5432/payload-example-multi-tenant

# ── Docker Compose ────────────────────────────────────────────────
# MongoDB connection — points to the Compose service named 'mongo'
DATABASE_URL=mongodb://mongo:27017/payload

# Strong secret used to sign Payload JWTs and cookies
PAYLOAD_SECRET=change_me_in_production

PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

NODE_ENV=production

# Set to 'true' to run the seed script on startup (dev only)
SEED_DB=false

# ── Mongo Express (dev profile) ───────────────────────────────────
ME_BASICAUTH_USERNAME=admin
ME_BASICAUTH_PASSWORD=admin
